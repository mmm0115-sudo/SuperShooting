#!/bin/bash
# Stellar Cascade .app ランチャー
DIR="$(cd "$(dirname "$0")/../Resources" && pwd)"

# java を探す（Finder 起動時は PATH が狭いので順に探索）
JAVA=""
for c in /usr/bin/java "$JAVA_HOME/bin/java" "$(/usr/libexec/java_home 2>/dev/null)/bin/java"; do
  if [ -x "$c" ]; then JAVA="$c"; break; fi
done
[ -z "$JAVA" ] && JAVA="java"

exec "$JAVA" -Xdock:name="灯火回廊" -Dsun.java2d.metal=true -jar "$DIR/StellarCascade.jar"
